      members: {
        title: 'Filing Structure & Regimes',
        subtitle: 'Validation parameters governing section paths and detailed Form 10IEA parameters.',
        sections: [
          {
            title: 'Filing Section Criteria',
            description: 'Categorization under Section 139 provisions.',
            fields: [
              {
                name: 'filingSectionType',
                label: 'Filed u/s (Section) *',
                type: 'select',
                options: [
                  '139(1)-On or before due date',
                  '139(4)-After due date',
                  '139(5)-Revised Return',
                  '139(8A)-Updated Return'
                ],
                required: true
              },
              {
                name: 'filedInResponseToNotice',
                label: 'Filed in response to notice u/s',
                type: 'select',
                options: [
                  '139(9)',
                  '142(1)',
                  '148',
                  '153A',
                  '153C'
                ],
                required: false
              },
              {
                name: 'dueDate139_1',
                label: 'Due Date u/s 139(1)',
                type: 'text',
                disabled: true,
                required: false
              },
              {
                name: 'receiptNumberOriginal',
                label: 'Receipt Number (if revised/defective)',
                type: 'text',
                required: true,
                condition: (state) => ['139(5)-Revised Return', '139(5)', '139(9)'].some(v => (state.details?.members?.filingSectionType || '').includes(v))
              },
              {
                name: 'dateOfOriginalReturn',
                label: 'Date of filing of original Return',
                type: 'text',
                placeholder: 'DD/MM/YYYY',
                required: true,
                condition: (state) => ['139(5)-Revised Return', '139(5)', '139(9)'].some(v => (state.details?.members?.filingSectionType || '').includes(v))
              },
              {
                name: 'noticeDin',
                label: 'Unique Number / DIN (for notice)',
                type: 'text',
                required: false,
                condition: (state) => ['139(9)', '142(1)', '148', '153A', '153C'].some(v => (state.details?.members?.filingSectionType || '').includes(v) || (state.details?.members?.filedInResponseToNotice || '').includes(v))
              },
              {
                name: 'noticeOrderDate',
                label: 'Date of such Notice or Order',
                type: 'text',
                placeholder: 'DD/MM/YYYY',
                required: false,
                condition: (state) => ['139(9)', '142(1)', '148', '153A', '153C'].some(v => (state.details?.members?.filingSectionType || '').includes(v) || (state.details?.members?.filedInResponseToNotice || '').includes(v))
              }
            ]
          },
          {
            title: 'Tax Regime Options (Form 10IEA Gates)',
            description: 'Gateway evaluation tracking section 115BAC compliance configurations.',
            fields: [
              {
                name: 'filedForm10IEAEarlier',
                label: 'Have you filed Form 10IEA within due date for any earlier AY for choosing old tax regime? *',
                type: 'select',
                options: [
                  'No',
                  'Yes'
                ],
                required: true
              },
              {
                name: 'form10IEADate2425',
                label: 'Date of filing Form 10IEA for AY 2024-25',
                type: 'text',
                required: false,
                conditionalOn: {
                  field: 'filedForm10IEAEarlier',
                  value: 'Yes'
                }
              },
              {
                name: 'form10IEAAckNumber',
                label: 'Acknowledgement number of Form 10IEA',
                type: 'text',
                required: false,
                conditionalOn: {
                  field: 'filedForm10IEAEarlier',
                  value: 'Yes'
                }
              },
              {
                name: 'optOutCurrentAY',
                label: 'Opt out of New Regime for current AY? *',
                type: 'select',
                options: [
                  'No',
                  'Yes'
                ],
                required: true
              },
              {
                name: 'finalRegimeSelection',
                label: 'Option for current AY (final selection) *',
                type: 'select',
                options: [
                  'Old',
                  'New'
                ],
                required: true
              }
            ]
          }
        ]
      },
      additional: {
        title: 'Special Provisos & Representatives',
        subtitle: 'Seventh Proviso data points and Representative Assessee configuration structures.',
        sections: [
          {
            title: 'Seventh Proviso u/s 139(1) Conditions',
            description: 'Mandatory evaluation parameters triggering filing parameters.',
            fields: [
              {
                name: 'filingUnderSeventhProviso',
