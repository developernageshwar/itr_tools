                type: 'select',
                options: [
                  'No',
                  'Yes'
                ],
                required: false
              },
              {
                name: 'depositedOverOneCrore',
                label: 'Deposited > ₹1 Crore in current account(s)?',
                type: 'select',
                options: [
                  'No',
                  'Yes'
                ],
                required: true,
                conditionalOn: {
