              },
              {
                name: 'repName',
                label: 'Name of representative assessee',
                type: 'text',
                required: true,
                conditionalOn: {
                  field: 'isRepresentative',
                  value: 'Yes'
                }
              },
              {
                name: 'repEmail',
                label: 'Email ID of representative assessee',
                type: 'text',
                required: true,
                conditionalOn: {
                  field: 'isRepresentative',
                  value: 'Yes'
                }
              },
              {
                name: 'repContact',
                label: 'Contact No. of representative assessee',
                type: 'text',
                required: true,
                conditionalOn: {
                  field: 'isRepresentative',
                  value: 'Yes'
                }
              },
              {
                name: 'repCapacity',
                label: 'Capacity of representative',
                type: 'select',
                options: [
                  'Self',
                  'Legal Heir',
                  'Guardian',
                  'Manager',
                  'Partner',
                  'Karta',
                  'Others'
                ],
                required: true,
                conditionalOn: {
                  field: 'isRepresentative',
                  value: 'Yes'
                }
              },
              {
                name: 'repAddress',
                label: 'Address of representative',
                type: 'text',
