                }
              }
            ]
          },
          {
            title: 'Representative Assessee Block',
            description: 'Authorized legal signee data fields layout maps.',
            fields: [
              {
                name: 'isRepresentative',
                label: 'Filed by representative assessee? *',
                type: 'select',
